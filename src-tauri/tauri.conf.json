{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "神笔写作",
  "version": "0.1.4",
  "identifier": "com.qgming.ainovelstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "神笔写作",
        "width": 1200,
        "height": 780,
        "minWidth": 1000,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/skills": "skills",
      "resources/agents": "agents",
      "resources/config": "config"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
