{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "神笔写作",
  "version": "0.1.9",
  "identifier": "com.qgming.ainovelstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "神笔写作",
        "width": 1100,
        "height": 800,
        "minWidth": 390,
        "minHeight": 800,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": {
      "resources/skills": "skills",
      "resources/agents": "agents",
      "resources/config": "config"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/qgming/ainovelstudio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBQUE5NkE2MjU3MDg5NjIKUldSaWlYQWxwcGFxR3QvS2d6enoyMkxUMUY3WUNMVjVHNExGUmNVSlZVdHVEdVJCT3hPT3M2U3gK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
